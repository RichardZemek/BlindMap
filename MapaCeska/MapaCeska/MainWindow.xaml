<Window x:Class="MapaCeska.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapa Česka" Height="600" Width="800"
        Loaded="MainWindow_Loaded">

    <Grid>

        <Image Name="MapImage"
           Source="img/czechia.png"
           Stretch="Uniform"
           MouseDown="MapImage_MouseDown"
           SizeChanged="MapImage_SizeChanged"/>

        <Canvas Name="OverlayCanvas"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="Transparent"/>

        <TextBlock Name="ScoreText"
               FontSize="16"
               Margin="10"
               IsHitTestVisible="False"/>

        <TextBlock Name="ActiveCityText"
               FontSize="20"
               FontWeight="Bold"
               Background="White"
               Margin="10"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               IsHitTestVisible="False"/>

    </Grid>

</Window>